{
  "name": "komal-shahid-portfolio",
  "version": "1.0.0",
  "description": "AI/ML Engineer Portfolio - Showcasing privacy-preserving healthcare AI and ethical data science solutions",
  "private": true,
  "author": "Komal Shahid <komal@komalshahid.dev>",
  "license": "MIT",
  "homepage": "https://komalshahid.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/komalshahid/portfolio.git"
  },
  "keywords": [
    "ai-engineer",
    "ml-engineer", 
    "data-scientist",
    "portfolio",
    "healthcare-ai",
    "privacy-preserving-ml",
    "ethical-ai",
    "next.js",
    "react",
    "typescript"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build", 
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --config=jest.a11y.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "cross-env ANALYZE=true next build",
    "export": "next export",
    "prepare": "husky install",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "framer-motion": "^10.16.0",
    "react-hook-form": "^7.47.0",
    "react-intersection-observer": "^9.5.0",
    "next-themes": "^0.2.1",
    "lucide-react": "^0.294.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "typescript": "^5.2.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "eslint": "^8.51.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-jsx-a11y": "^6.7.0",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/user-event": "^14.5.0",
    "jest-axe": "^8.0.0",
    "@playwright/test": "^1.39.0",
    "@storybook/addon-essentials": "^7.5.0",
    "@storybook/addon-interactions": "^7.5.0",
    "@storybook/addon-links": "^7.5.0",
    "@storybook/addon-a11y": "^7.5.0",
    "@storybook/blocks": "^7.5.0",
    "@storybook/nextjs": "^7.5.0",
    "@storybook/react": "^7.5.0",
    "@storybook/testing-library": "^0.2.0",
    "storybook": "^7.5.0",
    "@next/bundle-analyzer": "^14.0.0",
    "cross-env": "^7.0.0",
    "next-sitemap": "^4.2.0",
    "@axe-core/playwright": "^4.8.0"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.{js,jsx,ts,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "nextBundleAnalysis": {
    "budget": [
      {
        "path": "/_next/static/chunks/*.js",
        "maxSize": "200kb"
      },
      {
        "path": "/_next/static/css/*.css",
        "maxSize": "50kb"
      }
    ]
  }
}